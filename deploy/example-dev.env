# ===========================================================================
# DEAL MEALS - Development Environment Configuration
# ===========================================================================
#
# SETUP:
# 1. Copy this file:  cp deploy/example-dev.env .env
# 2. Fill in all values marked with CHANGE_ME
# 3. Start the app:   docker compose build --no-cache && docker compose up -d
#
# NOTE: After .env changes, use "docker compose up -d" (NOT restart!)
# ===========================================================================

# ---------------------------------------------------------------------------
# DOCKER / DEVELOPMENT OVERLAY
# ---------------------------------------------------------------------------
# Loads docker-compose.dev.yml automatically:
# - writable app volumes
# - dev container names
# - Adminer enabled
# - dev postgres volume
COMPOSE_PROJECT_NAME=deal-meals-dev
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
COMPOSE_PROFILES=dev

# ---------------------------------------------------------------------------
# PORTS
# ---------------------------------------------------------------------------
# Use dev ports so prod and dev can coexist on the same host.
APP_PORT=20070
ADMINER_PORT=8071

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DB_NAME=db_deal_meals
DB_USER=deal_meals_user
DB_PASSWORD=CHANGE_ME
DB_APP_USER=deal_meals_app
DB_APP_PASSWORD=CHANGE_ME

# DATABASE_URL is built automatically by docker-compose.yml from the values
# above. No need to set it here.

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------

# CSRF protection - comma-separated list of allowed hostnames
# Add your dev IP, DNS-name, FQDN, and/or reverse proxy domain here.
ALLOWED_HOSTS=localhost,127.0.0.1

# Reverse proxy support (leave commented out if accessing app directly)
# Set to your proxy's IP to trust X-Forwarded-For for rate limiting
# TRUSTED_PROXY=172.18.0.1

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------

# Debug mode - enables /docs, /redoc, /openapi.json API documentation
DEBUG=false

# Cache / delta
# compiled + delta is the built-in default.

# Recipe scrapers
# Incremental recipe counts are usable-recipe targets. The scraper may try a
# hidden buffer of extra candidate URLs to skip article/category/profile pages.
# Defaults: min 300 attempts, target * 50, absolute cap 2000.
# RECIPE_INCREMENTAL_ATTEMPT_MIN_CAP=300
# RECIPE_INCREMENTAL_ATTEMPT_TARGET_MULTIPLIER=50
# RECIPE_INCREMENTAL_ATTEMPT_HARD_CAP=2000

# Language / country matching
# Swedish is the default matcher/search config. For a real country backend,
# keep MATCHER_LANGUAGE and RECIPE_FTS_CONFIG aligned and rebuild
# found_recipes.search_vector.
# MATCHER_LANGUAGE=sv
# RECIPE_FTS_CONFIG=swedish

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# PostgreSQL tuning (safe defaults in docker-compose.yml)
# PG_SHARED_BUFFERS=256MB
# PG_WORK_MEM=16MB

# Force browser cleanup between scraper runs
FORCE_BROWSER_CLEANUP=true
