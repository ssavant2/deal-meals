# ===========================================================================
# DEAL MEALS - Production Environment Configuration
# ===========================================================================
#
# SETUP:
# 1. Download or copy this file to .env
# 2. Fill in all values marked with CHANGE_ME
# 3. Start the app:   docker compose up -d
#
# NOTE: After .env changes, use "docker compose up -d" (NOT restart!)
# ===========================================================================

# ---------------------------------------------------------------------------
# PORTS
# ---------------------------------------------------------------------------
APP_PORT=20080

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DB_NAME=db_deal_meals
DB_USER=deal_meals_user
DB_PASSWORD=CHANGE_ME_admin_password
DB_APP_USER=deal_meals_app
DB_APP_PASSWORD=CHANGE_ME_app_password

# DATABASE_URL is built automatically by docker-compose.yml from the values
# above. No need to set it here.

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
# Comma-separated hostnames allowed for POST/PUT/DELETE requests.
# Add your server's hostname/IP here. Include reverse proxy domains too.
ALLOWED_HOSTS=localhost,127.0.0.1

# Reverse proxy support (leave commented out if accessing app directly)
# Set to your proxy's IP to trust X-Forwarded-For for rate limiting
# TRUSTED_PROXY=172.18.0.1

# ---------------------------------------------------------------------------
# IMAGE VERSION
# ---------------------------------------------------------------------------
# Pin to a specific version, or use "latest" for newest.
DEAL_MEALS_VERSION=latest

# ---------------------------------------------------------------------------
# CACHE / DELTA
# ---------------------------------------------------------------------------
# Compiled cache with delta fast-path is the built-in default.
# Normal cache rebuilds auto-detect CPU cores but are capped to avoid memory
# spikes on larger hosts. Keep 3 unless you have measured lower/higher safely.
# Large recipe libraries may need lower caps or a larger web memory limit.
CACHE_REBUILD_MAX_WORKERS=3
# Delta verification previews are capped the same way: n-1 detected cores, but
# never above CACHE_REBUILD_MAX_WORKERS.
CACHE_DELTA_VERIFICATION_MAX_WORKERS=3
# The official cache path lets the compiled recipe/offer term-index choose
# routed recipe candidates. Set false only as a temporary legacy safety valve;
# delta will keep full-preview verification enabled in that mode.
# CACHE_TERM_INDEX_SKIP_FTS_PREFILTER=true

# ---------------------------------------------------------------------------
# RECIPE SCRAPERS
# ---------------------------------------------------------------------------
# Incremental recipe counts are usable-recipe targets. The scraper may try a
# hidden buffer of extra candidate URLs to skip article/category/profile pages.
# Defaults: min 300 attempts, target * 50, absolute cap 2000.
# RECIPE_INCREMENTAL_ATTEMPT_MIN_CAP=300
# RECIPE_INCREMENTAL_ATTEMPT_TARGET_MULTIPLIER=50
# RECIPE_INCREMENTAL_ATTEMPT_HARD_CAP=2000

# ---------------------------------------------------------------------------
# LANGUAGE / COUNTRY MATCHING
# ---------------------------------------------------------------------------
# Optional overrides. Leave unset for Swedish production defaults.
# MATCHER_LANGUAGE=sv
# RECIPE_FTS_CONFIG=swedish

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------
# DEBUG=false
# FORCE_HTTP=true          # Disable HTTPS (if no certs)

# PostgreSQL tuning (safe defaults in docker-compose.yml)
# PG_SHARED_BUFFERS=256MB
# PG_WORK_MEM=16MB

# Force browser cleanup between scraper runs
FORCE_BROWSER_CLEANUP=true
