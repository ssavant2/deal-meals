# Secrets - NEVER commit!
.env
.env.*
!.env.example
*.pem
*.key
certs/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Logs (runtime data, not code)
logs/*.log
*.log
app/logs/

# Cached images (can be re-downloaded)
app/static/recipe_images/

# Vendor assets (downloaded at Docker build time, copied at startup)
app/static/vendor/

# IDE folders
.idea/
.vscode/
*.swp
*.swo

# Claude Code internal files
.claude/

# Codex / private local workbench files (keep local only)
# Trackable deterministic support checks live in app/support_checks/.
CODEX.md
app/tests/

# AI instructions (dev-only)
CLAUDE.md
.github/copilot-instructions.md

# Dev-only tools and scripts
/utils/
app/scripts/

# Dev documentation (not needed in prod)
docs/code-review.md
docs/context.md
docs/MATCHER_LAYER_PARITY_PLAN.md
docs/v1_todo.md

# OS files
.DS_Store
Thumbs.db

# Docker volumes (if mounted locally)
postgres_data/

# Scraped data files (large, can be regenerated)
data/

# Temporary files
*.tmp
*.bak
