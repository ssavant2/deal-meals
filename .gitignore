# Secrets - NEVER commit!
.env
.env.*
!.env.example
*.pem
*.key
certs/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Logs (runtime data, not code)
logs/*.log
*.log
app/logs/

# Cached images (can be re-downloaded)
app/static/recipe_images/

# Vendor assets (downloaded at Docker build time, copied at startup)
app/static/vendor/

# IDE folders
.idea/
.vscode/
*.swp
*.swo

# Claude Code internal files
.claude/

# Codex / private batch-review working files (keep local only)
CODEX.md
app/tests/batch_review_*
app/tests/recipe_matching_review_template.md
app/tests/test_*.py
!app/tests/test_matching_sanity.py
app/tests/scrape_*_full_sortiment.py
app/tests/candidate_term_index_parity.py
app/tests/import_legacy_questions.py
app/tests/promote_legacy_confirmed_cases.py
app/tests/refresh_matcher_legacy_inventory_line_refs.py
app/tests/report_legacy_validator_adapter_candidates.py
app/tests/run_matcher_legacy_inventory_checks.py
app/tests/fixtures/matcher_layer_plan_initial_cases.json
app/tests/fixtures/matcher_legacy_questions_*.json
app/tests/fixtures/matcher_legacy_rule_inventory.json

# AI instructions (dev-only)
CLAUDE.md
.github/copilot-instructions.md

# Dev-only tools and scripts
/utils/
app/scripts/

# Dev documentation (not needed in prod)
docs/code-review.md
docs/context.md
docs/MATCHER_LAYER_PARITY_PLAN.md
docs/v1_todo.md

# OS files
.DS_Store
Thumbs.db

# Docker volumes (if mounted locally)
postgres_data/

# Scraped data files (large, can be regenerated)
data/

# Temporary files
*.tmp
*.bak
