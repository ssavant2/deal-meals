#!/usr/bin/env bash
set -euo pipefail

if [[ -f /app/cli/dm.py ]]; then
  exec python -m cli.dm "$@"
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"

exec docker compose exec -T -u appuser -w /app web python -m cli.dm "$@"
